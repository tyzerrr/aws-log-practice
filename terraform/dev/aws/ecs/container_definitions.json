[
  {
    "name": "nginx",
    "image": "public.ecr.aws/nginx/nginx:1.21",
    "cpu": 1024,
    "memory": 2048,
    "essential": true,
    "portMappings": [
      {"containerPort": 80, "protocol": "tcp"}
    ],
    "logConfiguration": {
      "logDriver": "awslogs",
      "options": {
        "awslogs-group": "${log_group}",
        "awslogs-region": "${region}",
        "awslogs-stream-prefix": "app"
      }
    }
  }
]
